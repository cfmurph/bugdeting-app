PORT=3000
DATABASE_URL=file:./data/budget.db
API_KEY=change-me-in-production

# Plaid Canada (sandbox: PLAID_ENV=sandbox)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_CLIENT_NAME=Budget App (CA)

# AES-GCM key material (min 32 chars recommended); hashed with SHA-256 internally
TOKEN_ENCRYPTION_KEY=dev-only-replace-with-long-random-string

# Optional: skip JWT verification for Plaid webhooks (local sandbox only)
# PLAID_SKIP_WEBHOOK_VERIFY=true

SYNC_CRON=15 6 * * *
SYNC_TZ=America/Toronto
